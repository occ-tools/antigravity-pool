DATABASE_URL="file:./dev.db"

# Required for Google OAuth refresh-token exchange.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Required if the admin dashboard/API is reachable from another machine.
# Local 127.0.0.1/localhost access is allowed without this token.
ADMIN_TOKEN=""

# Optional local proxy for Google endpoints.
HTTP_PROXY=""
HTTPS_PROXY=""
NO_PROXY="localhost,127.0.0.1"

# Optional AI Studio fallback key.
FALLBACK_GEMINI_API_KEY=""

# Pool tuning.
ANTIGRAVITY_POOL_TIMEOUT_MS=120000
ANTIGRAVITY_POOL_ACCOUNT_LEASE_MS=180000
ANTIGRAVITY_POOL_ACQUIRE_TIMEOUT_MS=15000
ANTIGRAVITY_POOL_ACQUIRE_POLL_MS=100
ANTIGRAVITY_POOL_SLOTS_PER_ACCOUNT=3
ANTIGRAVITY_POOL_GLOBAL_SLOTS=12
